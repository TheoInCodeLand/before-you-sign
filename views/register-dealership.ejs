<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Before You Sign</title>
  <meta name="description" content="Join South Africa's first ethical vehicle certification program. Register your dealership today.">
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
  <style>
    :root {
      --black: #0a0a0a;
      --white: #ffffff;
      --accent: #00a651;
      --accent-light: #00c25e;
      --accent-dark: #007237;
      --gray-50: #fafafa;
      --gray-100: #f4f4f5;
      --gray-200: #e4e4e7;
      --gray-300: #d4d4d8;
      --gray-400: #a1a1aa;
      --gray-500: #71717a;
      --gray-600: #52525b;
      --gray-700: #3f3f46;
      --gray-800: #27272a;
      --gray-900: #18181b;
      --danger: #ef4444;
      --danger-light: #fef2f2;
      --radius: 1.25rem;
      --radius-lg: 0rem;
      --radius-xl: 0rem;
      --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
      --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
      font-size: 16px;
    }

    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: linear-gradient(180deg, var(--gray-50) 0%, var(--white) 100%);
      color: var(--black);
      line-height: 1.6;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    /* Navigation */
    .nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border-bottom: 1px solid transparent;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .nav.scrolled {
      background: rgba(255, 255, 255, 0.95);
      border-bottom-color: var(--gray-200);
      box-shadow: var(--shadow-sm);
    }

    .nav-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .nav-brand {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      text-decoration: none;
      color: var(--black);
      font-weight: 800;
      font-size: 1.25rem;
      letter-spacing: -0.02em;
    }

    .nav-logo-icon {
      width: 40px;
      height: 40px;
      background: var(--black);
      color: var(--white);
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.125rem;
      transition: all 0.3s ease;
    }

    .nav-brand:hover .nav-logo-icon {
      background: var(--accent);
      transform: rotate(5deg) scale(1.05);
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      align-items: center;
    }

    .nav-link {
      text-decoration: none;
      color: var(--gray-600);
      font-weight: 500;
      font-size: 0.9375rem;
      transition: all 0.2s ease;
      position: relative;
    }

    .nav-link::after {
      content: '';
      position: absolute;
      bottom: -4px;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--accent);
      transition: width 0.3s ease;
    }

    .nav-link:hover {
      color: var(--black);
    }

    .nav-link:hover::after {
      width: 100%;
    }

    .nav-cta {
      background: var(--black);
      color: var(--white);
      padding: 0.625rem 1.25rem;
      border-radius: var(--radius);
      text-decoration: none;
      font-weight: 600;
      font-size: 0.875rem;
      transition: all 0.3s ease;
      border: 2px solid var(--black);
    }

    .nav-cta:hover {
      background: transparent;
      color: var(--black);
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }

    .mobile-menu-btn {
      display: none;
      background: none;
      border: none;
      font-size: 1.5rem;
      cursor: pointer;
      color: var(--black);
      padding: 0.5rem;
      border-radius: var(--radius);
      transition: background 0.2s;
    }

    /* Main Content */
    .main-content {
      padding-top: 120px;
      padding-bottom: 6rem;
      min-height: 100vh;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* Clean Form Card - No gimmicky borders */
    .form-card {
      background: var(--white);
      padding: 3rem;
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-xl);
      border: 1px solid var(--gray-200);
    }

    .form-header {
      text-align: center;
      margin-bottom: 3rem;
    }

    .form-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: rgba(16, 185, 129, 0.1);
      color: var(--accent-dark);
      padding: 0.5rem 1rem;
      border-radius: 50px;
      font-size: 0.875rem;
      font-weight: 600;
      margin-bottom: 1rem;
    }

    .form-title {
      font-size: 1.5rem;
      font-weight: 500;
      margin-bottom: 0.5rem;
      color: var(--black);
    }

    .form-subtitle {
      color: var(--gray-500);
      font-size: 1.125rem;
    }

    /* Section Headers */
    .section-header-form {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin: 2.5rem 0 1.5rem;
      padding-bottom: 0.75rem;
      border-bottom: 1px solid var(--gray-200);
    }

    .section-header-form:first-of-type {
      margin-top: 0;
    }

    .section-icon {
      width: 32px;
      height: 32px;
      background: var(--gray-100);
      color: var(--gray-600);
      border-radius: var(--radius);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 0.875rem;
    }

    .section-title-form {
      font-size: 1rem;
      font-weight: 700;
      color: var(--gray-900);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    /* Form Elements */
    .form-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
      margin-bottom: 1.5rem;
    }

    .form-grid.three-col {
      grid-template-columns: 1fr 1fr 1fr;
    }

    .form-group {
      margin-bottom: 0;
      position: relative;
    }

    .form-group.has-error .form-control {
      border-color: var(--danger);
      background: var(--danger-light);
    }

    .form-group.has-success .form-control {
      border-color: var(--accent);
    }

    .form-group.full-width {
      grid-column: 1 / -1;
    }

    .form-label {
      display: block;
      font-size: 0.875rem;
      font-weight: 600;
      color: var(--gray-700);
      margin-bottom: 0.5rem;
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }

    .required::after {
      content: '*';
      color: var(--danger);
      margin-left: 0.25rem;
    }

    .form-control {
      width: 100%;
      padding: 0.875rem 1rem;
      border: 1px solid var(--gray-200);
      border-radius: var(--radius);
      font-size: 0.9375rem;
      font-family: 'Inter', sans-serif;
      background: var(--gray-50);
      color: var(--black);
      transition: all 0.2s ease;
    }

    .form-control:hover {
      border-color: var(--gray-300);
      background: var(--gray-100);
    }

    .form-control:focus {
      outline: none;
      border-color: var(--accent);
      background: var(--white);
      box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.1);
    }

    textarea.form-control {
      resize: vertical;
      min-height: 100px;
    }

    /* Input with icon */
    .input-icon-wrapper {
      position: relative;
    }

    .input-icon {
      position: absolute;
      left: 1rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--gray-400);
      font-size: 1rem;
      transition: color 0.2s;
    }

    .form-control:focus ~ .input-icon {
      color: var(--accent);
    }

    .input-icon-wrapper .form-control {
      padding-left: 2.75rem;
    }

    /* Password toggle */
    .password-toggle {
      position: absolute;
      right: 1rem;
      top: 50%;
      transform: translateY(-50%);
      background: none;
      border: none;
      color: var(--gray-400);
      cursor: pointer;
      padding: 0.25rem;
      font-size: 1rem;
      transition: color 0.2s;
    }

    .password-toggle:hover {
      color: var(--gray-600);
    }

    /* Validation Message */
    .validation-message {
      font-size: 0.8125rem;
      margin-top: 0.375rem;
      display: flex;
      align-items: center;
      gap: 0.375rem;
      opacity: 0;
      transform: translateY(-5px);
      transition: all 0.2s;
    }

    .validation-message.show {
      opacity: 1;
      transform: translateY(0);
    }

    .validation-message.error {
      color: var(--danger);
    }

    .validation-message.success {
      color: var(--accent);
    }

    /* Alert Messages */
    .alert {
      padding: 1rem 1.25rem;
      border-radius: var(--radius);
      margin-bottom: 2rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.9375rem;
      font-weight: 500;
      animation: slideIn 0.3s ease;
    }

    @keyframes slideIn {
      from {
        opacity: 0;
        transform: translateY(-10px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .alert-error {
      background: var(--danger-light);
      color: var(--danger);
      border: 1px solid rgba(239, 68, 68, 0.2);
    }

    .alert-success {
      background: rgba(16, 185, 129, 0.1);
      color: var(--accent-dark);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    /* Submit Button */
    .btn-submit {
      width: 100%;
      background: var(--black);
      color: var(--white);
      border: none;
      padding: 1.125rem;
      border-radius: var(--radius);
      font-weight: 600;
      font-size: 1rem;
      cursor: pointer;
      transition: all 0.3s ease;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.75rem;
      margin-top: 2.5rem;
      position: relative;
      overflow: hidden;
    }

    .btn-submit:hover:not(:disabled) {
      background: var(--gray-800);
      transform: translateY(-2px);
      box-shadow: var(--shadow-lg);
    }

    .btn-submit:active:not(:disabled) {
      transform: translateY(0);
    }

    .btn-submit:disabled {
      opacity: 0.7;
      cursor: not-allowed;
    }

    .btn-submit.loading .btn-text {
      opacity: 0;
    }

    .btn-spinner {
      position: absolute;
      width: 20px;
      height: 20px;
      border: 2px solid transparent;
      border-top-color: var(--white);
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
      opacity: 0;
    }

    .btn-submit.loading .btn-spinner {
      opacity: 1;
    }

    @keyframes spin {
      to { transform: rotate(360deg); }
    }

    /* Footer Note */
    .form-footer {
      text-align: center;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--gray-200);
      color: var(--gray-500);
      font-size: 0.9375rem;
    }

    .form-footer a {
      color: var(--black);
      text-decoration: none;
      font-weight: 600;
      border-bottom: 1px solid var(--accent);
      transition: all 0.2s;
    }

    .form-footer a:hover {
      color: var(--accent);
    }

    /* Trust Badges */
    .trust-badges-form {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 2rem;
      flex-wrap: wrap;
    }

    .trust-badge {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.875rem;
      color: var(--gray-500);
      font-weight: 500;
    }

    .trust-badge i {
      color: var(--accent);
    }

    /* Footer */
    footer {
      background: var(--black);
      color: var(--gray-400);
      padding: 3rem 0;
      text-align: center;
    }

    .footer-content {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 2rem;
    }

    .footer-brand {
      color: var(--white);
      font-size: 1.25rem;
      font-weight: 800;
      margin-bottom: 1rem;
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
    }

    .footer-text {
      font-size: 0.875rem;
      max-width: 400px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fadeInUp 0.6s ease-out;
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .nav-links {
        display: none;
      }

      .mobile-menu-btn {
        display: block;
      }

      .form-card {
        padding: 2rem 1.5rem;
      }

      .form-grid,
      .form-grid.three-col {
        grid-template-columns: 1fr;
        gap: 1.25rem;
      }

      .form-title {
        font-size: 1.5rem;
      }

      .trust-badges-form {
        flex-direction: column;
        gap: 1rem;
        align-items: center;
      }
    }

    /* Selection color */
    ::selection {
      background: rgba(16, 185, 129, 0.2);
      color: var(--black);
    }

    /* Toast Notification */
    .toast {
      position: fixed;
      bottom: 2rem;
      right: 2rem;
      background: var(--black);
      color: var(--white);
      padding: 1rem 1.5rem;
      border-radius: var(--radius);
      box-shadow: var(--shadow-xl);
      display: flex;
      align-items: center;
      gap: 0.75rem;
      z-index: 9999;
      transform: translateX(150%);
      transition: transform 0.3s ease;
      max-width: 400px;
    }

    .toast.show {
      transform: translateX(0);
    }

    .toast.error {
      background: var(--danger);
    }

    .toast.success {
      background: var(--accent);
    }
  </style>
</head>
<body>

  <!-- Navigation -->
  <nav class="nav" id="nav">
    <div class="nav-container">
      <a href="/" class="nav-brand">
        <img src="/assets/logo-original.png" alt="Before You Sign" height="35" onerror="this.style.display='none'">
        <span style="font-weight: 800; font-size: 1.25rem;">Before You Sign</span>
      </a>
      <div class="nav-links">
        <a href="/#how-it-works" class="nav-link">How It Works</a>
        <a href="/#features" class="nav-link">Features</a>
        <a href="/vehicles" class="nav-link">Browse</a>
        <a href="/login" class="nav-link">Login</a>
        <a href="/register/dealership" class="nav-cta">Become Certified</a>
      </div>
      <button class="mobile-menu-btn" aria-label="Toggle menu" onclick="toggleMobileMenu()">
        <i class="fas fa-bars"></i>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobileMenu" style="display: none; position: fixed; inset: 0; background: var(--white); z-index: 1001; padding: 2rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
      <span style="font-weight: 800; font-size: 1.25rem;">Menu</span>
      <button onclick="toggleMobileMenu()" style="background: none; border: none; font-size: 1.5rem; cursor: pointer;">
        <i class="fas fa-times"></i>
      </button>
    </div>
    <div style="display: flex; flex-direction: column; gap: 1rem;">
      <a href="/#how-it-works" class="nav-link" style="font-size: 1.25rem; padding: 0.5rem 0;" onclick="toggleMobileMenu()">How It Works</a>
      <a href="/#features" class="nav-link" style="font-size: 1.25rem; padding: 0.5rem 0;" onclick="toggleMobileMenu()">Features</a>
      <a href="/vehicles" class="nav-link" style="font-size: 1.25rem; padding: 0.5rem 0;" onclick="toggleMobileMenu()">Browse</a>
      <a href="/login" class="nav-link" style="font-size: 1.25rem; padding: 0.5rem 0;" onclick="toggleMobileMenu()">Login</a>
      <a href="/register/dealership" class="nav-cta" style="text-align: center; margin-top: 1rem;" onclick="toggleMobileMenu()">Become Certified</a>
    </div>
  </div>

  <!-- Main Content -->
  <main class="main-content">
    <div class="container">
      <div class="form-card animate-fade-in">
        
        <div class="form-header">
          <div class="form-badge">
            <i class="fas fa-store"></i>
            <span>Dealership Application</span>
          </div>
          <h1 class="form-title">Join Our Certified Network</h1>
          <p class="form-subtitle">Transform your dealership with blockchain-verified vehicle histories</p>
        </div>

        <% if (error) { %>
          <div class="alert alert-error" role="alert" id="serverError">
            <i class="fas fa-exclamation-circle"></i>
            <span><%= error %></span>
          </div>
        <% } %>

        <form method="POST" action="/register/dealership" id="dealershipForm" novalidate>
          
          <!-- Account Information -->
          <div class="section-header-form">
            <div class="section-icon">
              <i class="fas fa-user"></i>
            </div>
            <h3 class="section-title-form">Account Information</h3>
          </div>

          <div class="form-grid">
            <div class="form-group" data-field="username">
              <label class="form-label required" for="username">Username</label>
              <div class="input-icon-wrapper">
                <i class="fas fa-user input-icon"></i>
                <input 
                  type="text" 
                  id="username"
                  name="username" 
                  class="form-control" 
                  required 
                  minlength="3"
                  maxlength="30"
                  pattern="[a-zA-Z0-9_]+"
                  placeholder="johnsmith"
                  autocomplete="username"
                  aria-describedby="usernameHelp"
                >
              </div>
              <span class="validation-message" id="usernameHelp"></span>
            </div>

            <div class="form-group" data-field="email">
              <label class="form-label required" for="email">Email Address</label>
              <div class="input-icon-wrapper">
                <i class="fas fa-envelope input-icon"></i>
                <input 
                  type="email" 
                  id="email"
                  name="email" 
                  class="form-control" 
                  required 
                  placeholder="john@dealership.com"
                  autocomplete="email"
                  aria-describedby="emailHelp"
                >
              </div>
              <span class="validation-message" id="emailHelp"></span>
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group" data-field="password">
              <label class="form-label required" for="password">Password</label>
              <div class="input-icon-wrapper" style="position: relative;">
                <i class="fas fa-lock input-icon"></i>
                <input 
                  type="password" 
                  id="password"
                  name="password" 
                  class="form-control" 
                  required 
                  minlength="8"
                  placeholder="••••••••"
                  autocomplete="new-password"
                  aria-describedby="passwordHelp"
                >
                <button type="button" class="password-toggle" onclick="togglePassword('password')" aria-label="Toggle password visibility">
                  <i class="fas fa-eye" id="password-icon"></i>
                </button>
              </div>
              <span class="validation-message" id="passwordHelp"></span>
            </div>

            <div class="form-group" data-field="confirmPassword">
              <label class="form-label required" for="confirmPassword">Confirm Password</label>
              <div class="input-icon-wrapper" style="position: relative;">
                <i class="fas fa-lock input-icon"></i>
                <input 
                  type="password" 
                  id="confirmPassword"
                  name="confirmPassword" 
                  class="form-control" 
                  required 
                  placeholder="••••••••"
                  autocomplete="new-password"
                  aria-describedby="confirmHelp"
                >
                <button type="button" class="password-toggle" onclick="togglePassword('confirmPassword')" aria-label="Toggle password visibility">
                  <i class="fas fa-eye" id="confirmPassword-icon"></i>
                </button>
              </div>
              <span class="validation-message" id="confirmHelp"></span>
            </div>
          </div>

          <!-- Business Information -->
          <div class="section-header-form">
            <div class="section-icon">
              <i class="fas fa-building"></i>
            </div>
            <h3 class="section-title-form">Business Information</h3>
          </div>

          <div class="form-group full-width" data-field="businessName" style="margin-bottom: 1.5rem;">
            <label class="form-label required" for="businessName">Business Name</label>
            <div class="input-icon-wrapper">
              <i class="fas fa-building input-icon"></i>
              <input 
                type="text" 
                id="businessName"
                name="businessName" 
                class="form-control" 
                required 
                minlength="2"
                placeholder="Premium Auto Dealership"
                autocomplete="organization"
              >
            </div>
            <span class="validation-message" id="businessNameHelp"></span>
          </div>

          <div class="form-grid three-col">
            <div class="form-group" data-field="registrationNumber">
              <label class="form-label required" for="registrationNumber">Registration Number</label>
              <input 
                type="text" 
                id="registrationNumber"
                name="registrationNumber" 
                class="form-control" 
                required 
                placeholder="CK2012/123456/07"
                aria-describedby="regHelp"
              >
              <span class="validation-message" id="regHelp"></span>
            </div>

            <div class="form-group" data-field="licenseNumber">
              <label class="form-label" for="licenseNumber">License Number</label>
              <input 
                type="text" 
                id="licenseNumber"
                name="licenseNumber" 
                class="form-control" 
                placeholder="Optional"
              >
            </div>

            <div class="form-group" data-field="yearEstablished">
              <label class="form-label" for="yearEstablished">Year Established</label>
              <input 
                type="number" 
                id="yearEstablished"
                name="yearEstablished" 
                class="form-control" 
                min="1900" 
                max="2026"
                placeholder="2020"
              >
              <span class="validation-message" id="yearHelp"></span>
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group" data-field="phone">
              <label class="form-label required" for="phone">Phone Number</label>
              <div class="input-icon-wrapper">
                <i class="fas fa-phone input-icon"></i>
                <input 
                  type="tel" 
                  id="phone"
                  name="phone" 
                  class="form-control" 
                  required 
                  placeholder="+27 83 744 0206"
                  autocomplete="tel"
                  pattern="[\+]?[0-9\s\-\(\)]+"
                  aria-describedby="phoneHelp"
                >
              </div>
              <span class="validation-message" id="phoneHelp"></span>
            </div>

            <div class="form-group" data-field="website">
              <label class="form-label" for="website">Website</label>
              <div class="input-icon-wrapper">
                <i class="fas fa-globe input-icon"></i>
                <input 
                  type="url" 
                  id="website"
                  name="website" 
                  class="form-control" 
                  placeholder="https://www.example.com"
                  autocomplete="url"
                >
              </div>
              <span class="validation-message" id="websiteHelp"></span>
            </div>
          </div>

          <div class="form-group full-width" data-field="address" style="margin-bottom: 1.5rem;">
            <label class="form-label required" for="address">Street Address</label>
            <div class="input-icon-wrapper">
              <i class="fas fa-map-marker-alt input-icon"></i>
              <input 
                type="text" 
                id="address"
                name="address" 
                class="form-control" 
                required 
                placeholder="123 Main Street, Sandton"
                autocomplete="street-address"
              >
            </div>
          </div>

          <div class="form-grid">
            <div class="form-group" data-field="city">
              <label class="form-label required" for="city">City</label>
              <input 
                type="text" 
                id="city"
                name="city" 
                class="form-control" 
                required 
                placeholder="Johannesburg"
                autocomplete="address-level2"
              >
            </div>

            <div class="form-group" data-field="postalCode">
              <label class="form-label" for="postalCode">Postal Code</label>
              <input 
                type="text" 
                id="postalCode"
                name="postalCode" 
                class="form-control" 
                placeholder="2196"
                autocomplete="postal-code"
                pattern="[0-9]*"
              >
              <span class="validation-message" id="postalHelp"></span>
            </div>
          </div>

          <div class="form-group full-width" data-field="operatingHours" style="margin-bottom: 1.5rem;">
            <label class="form-label" for="operatingHours">Operating Hours</label>
            <div class="input-icon-wrapper">
              <i class="fas fa-clock input-icon"></i>
              <input 
                type="text" 
                id="operatingHours"
                name="operatingHours" 
                class="form-control" 
                placeholder="Mon-Fri: 8:00 AM - 6:00 PM"
              >
            </div>
          </div>

          <div class="form-group full-width" data-field="description">
            <label class="form-label" for="description">Business Description</label>
            <textarea 
              id="description"
              name="description" 
              class="form-control" 
              rows="4" 
              placeholder="Tell us about your dealership, specializations, and what makes you unique..."
              maxlength="1000"
            ></textarea>
            <span class="validation-message" id="descHelp" style="justify-content: flex-end;"></span>
          </div>

          <button type="submit" class="btn-submit" id="submitBtn">
            <span class="btn-text">
              <i class="fas fa-shield-alt"></i>
              Register Dealership
            </span>
            <span class="btn-spinner"></span>
          </button>

        </form>

        <div class="trust-badges-form">
          <div class="trust-badge">
            <i class="fas fa-lock"></i>
            <span>Bank-Level Security</span>
          </div>
          <div class="trust-badge">
            <i class="fas fa-check-circle"></i>
            <span>Instant Verification</span>
          </div>
          <div class="trust-badge">
            <i class="fas fa-user-shield"></i>
            <span>POPIA Compliant</span>
          </div>
        </div>

        <div class="form-footer">
          <p>Already have an account? <a href="/login">Sign in here</a></p>
        </div>

      </div>
    </div>
  </main>

  <!-- Simple Footer -->
  <footer>
    <div class="footer-content">
      <div class="footer-brand">
        <i class="fas fa-shield-alt" style="color: var(--accent);"></i>
        <span>Before You Sign</span>
      </div>
      <p class="footer-text">
        Empowering car buyers with verified data and holding dealerships accountable through transparent verification.
      </p>
      <p style="margin-top: 1.5rem; font-size: 0.875rem; opacity: 0.6;">
        © <%= new Date().getFullYear() %> Before You Sign. All rights reserved.
      </p>
    </div>
  </footer>

  <!-- Toast Notification -->
  <div id="toast" class="toast" role="alert" aria-live="polite">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage">Action completed successfully</span>
  </div>

  <script>
    // Form state management
    const form = document.getElementById('dealershipForm');
    const submitBtn = document.getElementById('submitBtn');
    const STORAGE_KEY = 'dealership_registration_draft';

    // Validation rules
    const validators = {
      username: {
        validate: (value) => {
          if (value.length < 3) return { valid: false, message: 'Username must be at least 3 characters' };
          if (!/^[a-zA-Z0-9_]+$/.test(value)) return { valid: false, message: 'Only letters, numbers, and underscores allowed' };
          return { valid: true, message: 'Looks good!' };
        }
      },
      email: {
        validate: (value) => {
          const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
          if (!emailRegex.test(value)) return { valid: false, message: 'Please enter a valid email address' };
          return { valid: true, message: 'Valid email' };
        }
      },
      password: {
        validate: (value) => {
          if (value.length < 8) return { valid: false, message: 'Password must be at least 8 characters' };
          const strength = calculatePasswordStrength(value);
          if (strength < 2) return { valid: false, message: 'Add numbers or special characters for stronger password' };
          return { valid: true, message: 'Strong password' };
        }
      },
      confirmPassword: {
        validate: (value) => {
          const password = document.getElementById('password').value;
          if (value !== password) return { valid: false, message: 'Passwords do not match' };
          if (value === '') return { valid: false, message: 'Please confirm your password' };
          return { valid: true, message: 'Passwords match' };
        }
      },
      phone: {
        validate: (value) => {
          const phoneRegex = /^[\+\d\s\-\(\)]{10,}$/;
          if (!phoneRegex.test(value)) return { valid: false, message: 'Please enter a valid phone number' };
          return { valid: true, message: 'Valid number' };
        }
      },
      yearEstablished: {
        validate: (value) => {
          if (!value) return { valid: true };
          const year = parseInt(value);
          const currentYear = new Date().getFullYear();
          if (year < 1900 || year > currentYear) return { valid: false, message: `Year must be between 1900 and ${currentYear}` };
          return { valid: true, message: '' };
        }
      },
      website: {
        validate: (value) => {
          if (!value) return { valid: true };
          try {
            new URL(value);
            return { valid: true, message: 'Valid URL' };
          } catch {
            return { valid: false, message: 'Please enter a valid URL (include https://)' };
          }
        }
      },
      postalCode: {
        validate: (value) => {
          if (!value) return { valid: true };
          if (!/^\d+$/.test(value)) return { valid: false, message: 'Only numbers allowed' };
          return { valid: true, message: '' };
        }
      },
      description: {
        validate: (value) => {
          const remaining = 1000 - value.length;
          return { valid: true, message: `${remaining} characters remaining` };
        }
      }
    };

    // Calculate password strength (0-4)
    function calculatePasswordStrength(password) {
      let strength = 0;
      if (password.length >= 8) strength++;
      if (password.match(/[a-z]/) && password.match(/[A-Z]/)) strength++;
      if (password.match(/\d/)) strength++;
      if (password.match(/[^a-zA-Z\d]/)) strength++;
      return strength;
    }

    // Real-time validation
    function validateField(field) {
      const fieldName = field.name;
      const value = field.value.trim();
      const group = field.closest('.form-group');
      const helpText = document.getElementById(fieldName + 'Help') || group.querySelector('.validation-message');
      
      if (!validators[fieldName]) return true;

      const result = validators[fieldName].validate(value);
      
      // Update UI
      group.classList.remove('has-error', 'has-success');
      helpText.classList.remove('show', 'error', 'success');
      
      if (value !== '' || field.hasAttribute('required')) {
        if (result.valid) {
          group.classList.add('has-success');
          helpText.classList.add('show', 'success');
          helpText.innerHTML = `<i class="fas fa-check-circle"></i> ${result.message}`;
          return true;
        } else {
          group.classList.add('has-error');
          helpText.classList.add('show', 'error');
          helpText.innerHTML = `<i class="fas fa-exclamation-circle"></i> ${result.message}`;
          return false;
        }
      }
      return true;
    }

    // Attach validation listeners
    form.querySelectorAll('input, textarea').forEach(field => {
      // Validate on blur
      field.addEventListener('blur', () => validateField(field));
      
      // Validate on input (with debounce for performance)
      let timeout;
      field.addEventListener('input', (e) => {
        clearTimeout(timeout);
        timeout = setTimeout(() => {
          validateField(field);
          saveFormDraft();
        }, 300);
      });
    });

    // Password confirmation validation triggers when password changes
    document.getElementById('password').addEventListener('input', () => {
      const confirmField = document.getElementById('confirmPassword');
      if (confirmField.value) validateField(confirmField);
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Validate all fields
      let isValid = true;
      const requiredFields = form.querySelectorAll('[required]');
      
      requiredFields.forEach(field => {
        if (!validateField(field)) {
          isValid = false;
          // Focus first invalid field
          if (isValid === false && !form.querySelector('.has-error:focus')) {
            field.focus();
          }
        }
      });

      if (!isValid) {
        showToast('Please fix the errors above', 'error');
        // Scroll to first error
        const firstError = form.querySelector('.has-error');
        if (firstError) {
          firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return;
      }

      // Show loading state
      submitBtn.disabled = true;
      submitBtn.classList.add('loading');

      // Simulate submission or proceed
      try {
        // Remove draft on successful submission
        localStorage.removeItem(STORAGE_KEY);
        
        // Actually submit the form
        form.submit();
      } catch (error) {
        submitBtn.disabled = false;
        submitBtn.classList.remove('loading');
        showToast('Something went wrong. Please try again.', 'error');
      }
    });

    // Password visibility toggle
    function togglePassword(fieldId) {
      const field = document.getElementById(fieldId);
      const icon = document.getElementById(fieldId + '-icon');
      
      if (field.type === 'password') {
        field.type = 'text';
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash');
      } else {
        field.type = 'password';
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye');
      }
    }

    // Save form draft to localStorage
    function saveFormDraft() {
      const formData = new FormData(form);
      const data = {};
      formData.forEach((value, key) => {
        if (key !== 'password' && key !== 'confirmPassword') { // Don't save passwords
          data[key] = value;
        }
      });
      localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
    }

    // Restore form draft
    function restoreFormDraft() {
      const saved = localStorage.getItem(STORAGE_KEY);
      if (saved) {
        try {
          const data = JSON.parse(saved);
          Object.keys(data).forEach(key => {
            const field = form.querySelector(`[name="${key}"]`);
            if (field && !field.value) {
              field.value = data[key];
            }
          });
        } catch (e) {
          console.error('Error restoring form draft:', e);
        }
      }
    }

    // Toast notification
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toastMessage');
      
      toast.className = 'toast ' + type;
      toastMessage.textContent = message;
      
      // Update icon based on type
      const icon = toast.querySelector('i');
      if (type === 'error') {
        icon.className = 'fas fa-exclamation-circle';
      } else {
        icon.className = 'fas fa-check-circle';
      }
      
      toast.classList.add('show');
      
      setTimeout(() => {
        toast.classList.remove('show');
      }, 5000);
    }

    // Mobile menu toggle
    function toggleMobileMenu() {
      const menu = document.getElementById('mobileMenu');
      const currentDisplay = menu.style.display;
      menu.style.display = currentDisplay === 'none' ? 'block' : 'none';
      document.body.style.overflow = currentDisplay === 'none' ? 'hidden' : '';
    }

    // Navbar scroll effect
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    }, { passive: true });

    // Close mobile menu on resize
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) {
        document.getElementById('mobileMenu').style.display = 'none';
        document.body.style.overflow = '';
      }
    });

    // Auto-save every 30 seconds as backup
    setInterval(saveFormDraft, 30000);

    // Restore draft on load
    document.addEventListener('DOMContentLoaded', () => {
      restoreFormDraft();
      
      // Check if there's a server error and scroll to it
      const serverError = document.getElementById('serverError');
      if (serverError) {
        serverError.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });

    // Warn before leaving if form has unsaved changes
    let formDirty = false;
    form.addEventListener('input', () => {
      formDirty = true;
    });

    window.addEventListener('beforeunload', (e) => {
      if (formDirty && !submitBtn.disabled) {
        e.preventDefault();
        e.returnValue = '';
      }
    });
  </script>

</body>
</html>