<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Error | Before You Sign</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --black: #0a0a0a;
            --white: #ffffff;
            --accent: #00a651;
            --accent-light: #00c25e;
            --accent-dark: #007237;
            --gray-50: #fafafa;
            --gray-100: #f4f4f5;
            --gray-200: #e4e4e7;
            --gray-300: #d4d4d8;
            --gray-400: #a1a1aa;
            --gray-500: #71717a;
            --gray-600: #52525b;
            --gray-700: #3f3f46;
            --gray-800: #27272a;
            --gray-900: #18181b;
            --danger: #ef4444;
            --warning: #f59e0b;
            --radius: 1.25rem;
            --radius-lg: 0.2rem;
            --radius-xl: 0.2rem;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
            --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -4px rgba(0, 0, 0, 0.1);
            --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--white);
            color: var(--black);
            line-height: 1.6;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* Navigation */
        .nav {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            background: rgba(255, 255, 255, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid transparent;
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav.scrolled {
            background: rgba(255, 255, 255, 0.95);
            border-bottom-color: var(--gray-200);
            box-shadow: var(--shadow-sm);
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            text-decoration: none;
            color: var(--black);
            font-weight: 800;
            font-size: 1.25rem;
            letter-spacing: -0.02em;
        }

        .nav-brand img {
            height: 35px;
            width: auto;
        }

        .nav-brand span {
            font-weight: 500;
            font-size: 1rem;
        }

        /* Error Section */
        .error-section {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 120px 2rem 4rem;
            background: linear-gradient(180deg, var(--gray-50) 0%, var(--white) 100%);
            position: relative;
            overflow: hidden;
        }

        .error-bg-pattern {
            position: absolute;
            inset: 0;
            background-image: 
                radial-gradient(circle at 20% 50%, rgba(239, 68, 68, 0.03) 0%, transparent 50%),
                radial-gradient(circle at 80% 20%, rgba(0, 166, 81, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 60% 80%, rgba(0, 0, 0, 0.02) 0%, transparent 30%);
            pointer-events: none;
        }

        .error-container {
            max-width: 600px;
            width: 100%;
            position: relative;
            z-index: 1;
        }

        /* Error Card */
        .error-card {
            background: var(--white);
            padding: 3rem;
            border-radius: var(--radius-xl);
            box-shadow: var(--shadow-xl), 0 0 0 1px var(--gray-200);
            text-align: center;
            animation: fadeInUp 0.6s ease-out;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Status Icon */
        .status-icon-wrapper {
            width: 80px;
            height: 80px;
            background: rgba(239, 68, 68, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            position: relative;
        }

        .status-icon-wrapper::before {
            content: '';
            position: absolute;
            inset: -4px;
            border-radius: 50%;
            border: 2px solid rgba(239, 68, 68, 0.2);
            animation: pulse 2s infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.05); opacity: 0.5; }
        }

        .status-icon {
            font-size: 2rem;
            color: var(--danger);
        }

        /* Error Code Display */
        .error-code-display {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.875rem;
            font-weight: 500;
            color: var(--gray-400);
            margin-bottom: 0.5rem;
            letter-spacing: 0.1em;
            text-transform: uppercase;
        }

        /* Title */
        .error-title {
            font-size: clamp(1.5rem, 4vw, 2rem);
            font-weight: 700;
            margin-bottom: 1rem;
            letter-spacing: -0.02em;
            color: var(--black);
        }

        /* Message */
        .error-message {
            font-size: 1rem;
            color: var(--gray-600);
            line-height: 1.7;
            margin-bottom: 2rem;
        }

        /* Action Area */
        .error-actions {
            display: flex;
            gap: 1rem;
            justify-content: center;
            flex-wrap: wrap;
        }

        .btn-primary {
            background: var(--accent);
            color: var(--white);
            padding: 0.875rem 1.75rem;
            border-radius: var(--radius);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9375rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            border: 2px solid var(--accent);
            cursor: pointer;
            border: none;
        }

        .btn-primary:hover {
            background: var(--accent-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow-lg);
        }

        .btn-secondary {
            background: transparent;
            color: var(--gray-700);
            padding: 0.875rem 1.75rem;
            border-radius: var(--radius);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9375rem;
            transition: all 0.3s ease;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            border: 2px solid var(--gray-300);
        }

        .btn-secondary:hover {
            border-color: var(--black);
            color: var(--black);
            transform: translateY(-2px);
        }

        /* Support Section */
        .support-section {
            margin-top: 2rem;
            padding-top: 2rem;
            border-top: 1px solid var(--gray-200);
        }

        .support-text {
            font-size: 0.875rem;
            color: var(--gray-500);
            margin-bottom: 0.75rem;
        }

        .support-link {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--accent);
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9375rem;
            transition: all 0.2s ease;
        }

        .support-link:hover {
            color: var(--accent-dark);
            gap: 0.75rem;
        }

        /* Error Details (for debugging) */
        .error-details {
            margin-top: 2rem;
            padding: 1rem;
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            border: 1px solid var(--gray-200);
            text-align: left;
            display: none;
        }

        .error-details.show {
            display: block;
        }

        .error-details-toggle {
            background: none;
            border: none;
            color: var(--gray-500);
            font-size: 0.875rem;
            cursor: pointer;
            margin-top: 1.5rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: color 0.2s;
        }

        .error-details-toggle:hover {
            color: var(--gray-700);
        }

        .error-details-content {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8125rem;
            color: var(--gray-600);
            overflow-x: auto;
            white-space: pre-wrap;
            word-break: break-word;
        }

        /* Footer */
        .simple-footer {
            background: var(--black);
            color: var(--gray-400);
            padding: 2rem;
            text-align: center;
            font-size: 0.875rem;
        }

        .simple-footer a {
            color: var(--white);
            text-decoration: none;
            transition: color 0.2s;
        }

        .simple-footer a:hover {
            color: var(--accent);
        }

        /* Responsive */
        @media (max-width: 640px) {
            .error-section {
                padding: 100px 1rem 3rem;
            }

            .error-card {
                padding: 2rem 1.5rem;
            }

            .error-actions {
                flex-direction: column;
            }

            .btn-primary, .btn-secondary {
                width: 100%;
                justify-content: center;
            }
        }

        /* Animation for status icon on load */
        .status-icon-wrapper {
            animation: scaleIn 0.5s ease-out;
        }

        @keyframes scaleIn {
            from {
                transform: scale(0);
                opacity: 0;
            }
            to {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="nav" id="nav">
        <div class="nav-container">
            <a href="/" class="nav-brand">
                <img src="/assets/logo-original.png" alt="Before You Sign">
                <span>Before You Sign</span>
            </a>
        </div>
    </nav>

    <!-- Error Section -->
    <section class="error-section">
        <div class="error-bg-pattern"></div>
        
        <div class="error-container">
            <div class="error-card">
                <!-- Status Icon -->
                <div class="status-icon-wrapper">
                    <i class="fas fa-exclamation-triangle status-icon"></i>
                </div>

                <!-- Error Code (if available) -->
                <% if (typeof statusCode !== 'undefined' && statusCode) { %>
                    <div class="error-code-display">Error <%= statusCode %></div>
                <% } %>

                <!-- Title -->
                <h1 class="error-title">Something went wrong</h1>

                <!-- Message -->
                <p class="error-message">
                    <%= message || "We encountered an unexpected issue while processing your request. Our team has been notified and we're working to resolve this." %>
                </p>

                <!-- Actions -->
                <div class="error-actions">
                    <a href="/" class="btn-primary">
                        <i class="fas fa-home"></i>
                        Return Home
                    </a>
                    <button onclick="window.history.back()" class="btn-secondary">
                        <i class="fas fa-arrow-left"></i>
                        Go Back
                    </button>
                </div>

                <!-- Support Section -->
                <div class="support-section">
                    <p class="support-text">Need immediate assistance?</p>
                    <a href="mailto:mxolisimkhonza23@gmail.com" class="support-link">
                        <i class="fas fa-envelope"></i>
                        Contact Support
                        <i class="fas fa-arrow-right" style="font-size: 0.75rem;"></i>
                    </a>
                </div>

                <!-- Error Details Toggle (for development) -->
                <% if (typeof error !== 'undefined' && error && process.env.NODE_ENV === 'development') { %>
                    <button class="error-details-toggle" onclick="toggleDetails()">
                        <i class="fas fa-code"></i>
                        Show Technical Details
                    </button>
                    <div class="error-details" id="errorDetails">
                        <div class="error-details-content"><%= error.stack || error %></div>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- Simple Footer -->
    <footer class="simple-footer">
        <p>&copy; <%= new Date().getFullYear() %> Before You Sign. All rights reserved.</p>
    </footer>

    <script>
        // Navbar scroll effect
        const nav = document.getElementById('nav');
        
        window.addEventListener('scroll', () => {
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        }, { passive: true });

        // Toggle error details
        function toggleDetails() {
            const details = document.getElementById('errorDetails');
            const toggle = document.querySelector('.error-details-toggle');
            
            if (details.classList.contains('show')) {
                details.classList.remove('show');
                toggle.innerHTML = '<i class="fas fa-code"></i> Show Technical Details';
            } else {
                details.classList.add('show');
                toggle.innerHTML = '<i class="fas fa-code"></i> Hide Technical Details';
            }
        }

        // Trigger nav effect on load
        window.dispatchEvent(new Event('scroll'));
    </script>
</body>
</html>