<!-- FAQ Schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How does Before You Sign work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Before You Sign uses QR codes on certified vehicles. Simply scan the code with your phone camera to instantly view a 10-point verification report including VIN validation, mileage history, accident records, and ownership chain."
      }
    },
    {
      "@type": "Question",
      "name": "Is Before You Sign free to use?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! Vehicle verification reports are completely free for buyers. No registration or app download is required - just scan and verify."
      }
    },
    {
      "@type": "Question",
      "name": "What information does the verification report include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our 10-point verification includes: VIN authentication, mileage verification, accident history, service records, ownership chain, recall checks, title status, odometer validation, structural damage assessment, and theft records."
      }
    },
    {
      "@type": "Question",
      "name": "How can dealerships become certified?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dealerships can apply for certification through our portal. We verify business credentials, inspect vehicle inventory processes, and provide QR code generation tools for transparent vehicle listings."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if the vehicle doesn't match the report?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If reality doesn't match our verification report, our dispute resolution team will mediate under the Consumer Protection Act. We have a 100% resolution rate and money-back guarantee."
      }
    }
  ]
}
</script>

