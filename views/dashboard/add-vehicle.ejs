  <script>
    // Frontend validation in add-vehicle.html
    document.querySelector('input[name="mileage"]').addEventListener('blur', function() {
        const mileage = parseInt(this.value);
        const year = parseInt(document.querySelector('select[name="year"]').value);
        const currentYear = new Date().getFullYear();
        const age = currentYear - year;
        
        // Expected mileage: 15,000-30,000 km per year
        const expectedMin = age * 10000;
        const expectedMax = age * 35000;
        
        if (mileage < expectedMin * 0.5) {
            alert('⚠️ Warning: Mileage seems unusually low for vehicle age. Please verify odometer accuracy.');
            this.style.borderColor = '#f59e0b';
        } else if (mileage > expectedMax * 1.5) {
            alert('⚠️ Warning: Mileage seems unusually high for vehicle age. Please verify service records.');
            this.style.borderColor = '#f59e0b';
        }
    });
  </script>
