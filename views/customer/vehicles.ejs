  <%- include('../partials/breadcrumbs.ejs', { 
      items: [
          {name: 'Home', url: '/'},
          {name: 'Browse Vehicles', url: '/vehicles', active: true}
      ]
  }) %>

  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-container">
      <div class="hero-badge">
        <i class="fas fa-check-circle"></i>
        <span><%= totalVehicles || vehicles.length %>+ Verified Vehicles</span>
      </div>
      <h1 class="hero-title">Find Your <span>Verified</span> Vehicle</h1>
      <p class="hero-subtitle">
        Browse certified vehicles with complete verified histories from ethical dealerships across South Africa
      </p>

      <div class="search-container">
        <div class="search-tabs">
          <button class="search-tab active" data-tab="vin">
            <i class="fas fa-barcode"></i> Search by VIN
          </button>
          <button class="search-tab" data-tab="scan" onclick="openQrModal()">
            <i class="fas fa-qrcode"></i> Scan QR Code
          </button>
        </div>

        <form action="/vehicles" method="GET" class="search-form" id="searchForm">
          <div class="search-input-wrapper">
            <i class="fas fa-search search-icon"></i>
            <input 
              type="text" 
              name="vin" 
              class="search-input" 
              placeholder="Enter 17-digit VIN number..."
              maxlength="17"
              value="<%= locals.filters && filters.vin ? filters.vin : '' %>"
            >
          </div>
          <button type="submit" class="search-btn">
            <i class="fas fa-shield-alt"></i> Verify Vehicle
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Filter Section -->
  <section class="filter-section">
    <div class="filter-container">
      <span class="filter-label">
        <i class="fas fa-filter"></i> Filters:
      </span>
      
      <div style="display: flex; justify-content: space-evenly; width: 100%; flex-wrap: wrap; gap: 1rem;">
        <select class="filter-select" name="make" onchange="applyFilter('make', this.value)">
          <option value="">All Makes</option>
          <option value="BMW" <%= locals.filters && filters.make === 'BMW' ? 'selected' : '' %>>BMW</option>
          <option value="Mercedes" <%= locals.filters && filters.make === 'Mercedes' ? 'selected' : '' %>>Mercedes</option>
          <option value="Audi" <%= locals.filters && filters.make === 'Audi' ? 'selected' : '' %>>Audi</option>
          <option value="Toyota" <%= locals.filters && filters.make === 'Toyota' ? 'selected' : '' %>>Toyota</option>
          <option value="VW" <%= locals.filters && filters.make === 'VW' ? 'selected' : '' %>>VW</option>
        </select>

        <select class="filter-select" name="year" onchange="applyFilter('year', this.value)">
          <option value="">All Years</option>
          <option value="2024" <%= locals.filters && filters.year === '2024' ? 'selected' : '' %>>2024</option>
          <option value="2023" <%= locals.filters && filters.year === '2023' ? 'selected' : '' %>>2023</option>
          <option value="2022" <%= locals.filters && filters.year === '2022' ? 'selected' : '' %>>2022</option>
          <option value="2021" <%= locals.filters && filters.year === '2021' ? 'selected' : '' %>>2021</option>
          <option value="2020" <%= locals.filters && filters.year === '2020' ? 'selected' : '' %>>2020</option>
        </select>

        <select class="filter-select" name="price" onchange="applyFilter('maxPrice', this.value)">
          <option value="">Any Price</option>
          <option value="200000" <%= locals.filters && filters.maxPrice === '200000' ? 'selected' : '' %>>Under R200k</option>
          <option value="500000" <%= locals.filters && filters.maxPrice === '500000' ? 'selected' : '' %>>Under R500k</option>
          <option value="1000000" <%= locals.filters && filters.maxPrice === '1000000' ? 'selected' : '' %>>Under R1M</option>
          <option value="2000000" <%= locals.filters && filters.maxPrice === '2000000' ? 'selected' : '' %>>Under R2M</option>
        </select>
      </div>

      <span class="results-count">
        Showing <%= vehicles.length %> of <%= totalVehicles || vehicles.length %> vehicles
      </span>

      <% if (locals.filters && Object.keys(filters).some(k => filters[k])) { %>
        <a href="/vehicles" class="filter-clear">
          <i class="fas fa-times"></i> Clear Filters
        </a>
      <% } %>
    </div>
  </section>

  <!-- Vehicles Grid -->
  <section class="vehicles-section">
    <% if (vehicles.length === 0) { %>
      <div class="empty-state">
        <div class="empty-icon">
          <i class="fas fa-search"></i>
        </div>
        <h3 class="empty-title">No vehicles found</h3>
        <p class="empty-text">Try adjusting your search criteria or filters to find what you're looking for.</p>
        <a href="/vehicles" class="empty-btn">
          <i class="fas fa-undo"></i> Clear All Filters
        </a>
      </div>
    <% } else { %>
      <div class="vehicles-grid">
        <% vehicles.forEach(function(vehicle) { %>
          <article class="vehicle-card">
            
            <div class="vehicle-image">
              <% 
                let images = [];
                if (vehicle.image_urls) {
                  try {
                    images = JSON.parse(vehicle.image_urls);
                    if (!Array.isArray(images)) images = [images];
                  } catch(e) {
                    images = vehicle.image_urls ? [vehicle.image_urls] : [];
                  }
                }
                const mainImage = images[0] || '/assets/car-placeholder.jpg';
                const imageCount = images.length;
              %>
              <img src="<%= mainImage %>" alt="..." loading="lazy" onerror="this.src='/assets/car-placeholder.jpg'">
              
              <% if (imageCount > 1) { %>
                <div style="position: absolute; bottom: 1rem; right: 1rem; background: rgba(0,0,0,0.7); color: white; padding: 0.25rem 0.75rem; border-radius: var(--radius); font-size: 0.75rem; font-weight: 600;">
                  <i class="fas fa-images"></i> <%= imageCount %> photos
                </div>
              <% } %>
              
              <div class="verified-badge">
                <i class="fas fa-check-circle"></i> Verified
              </div>
              <span class="vehicle-year"><%= vehicle.year %></span>
            </div>

            <!-- Vehicle Content -->
            <div class="vehicle-content">
              <div class="vehicle-header">
                <a href="/vehicle/<%= vehicle.id %>" class="vehicle-title">
                  <%= vehicle.year %> <%= vehicle.make %> <%= vehicle.model %>
                </a>
                <div class="vehicle-dealer">
                  <i class="fas fa-store"></i>
                  <%= vehicle.business_name || 'Certified Dealer' %>
                </div>
              </div>

              <div class="vehicle-specs">
                <div class="spec-item">
                  <i class="fas fa-tachometer-alt"></i>
                  <span><%= vehicle.mileage ? vehicle.mileage.toLocaleString() + ' km' : 'N/A' %></span>
                </div>
                <div class="spec-item">
                  <i class="fas fa-gas-pump"></i>
                  <span><%= vehicle.fuel_type || 'N/A' %></span>
                </div>
                <div class="spec-item">
                  <i class="fas fa-cog"></i>
                  <span><%= vehicle.transmission || 'N/A' %></span>
                </div>
                <div class="spec-item">
                  <i class="fas fa-palette"></i>
                  <span><%= vehicle.color || 'N/A' %></span>
                </div>
              </div>

              <div class="vehicle-footer">
                <div class="vehicle-price">
                  <% if (vehicle.price) { %>
                    R<%= vehicle.price.toLocaleString() %>
                  <% } else { %>
                    POA
                    <span>Contact for price</span>
                  <% } %>
                </div>
                <a href="/vehicle/<%= vehicle.id %>" class="view-btn">
                  View Details <i class="fas fa-arrow-right"></i>
                </a>
              </div>
            </div>
          </article>
        <% }); %>
      </div>

      <!-- Pagination -->
      <% if (locals.totalPages && totalPages > 1) { %>
        <div class="pagination">
          <% if (currentPage > 1) { %>
            <a href="/vehicles?page=<%= currentPage - 1 %><%= buildQueryString(filters) %>" class="page-btn">
              <i class="fas fa-chevron-left"></i>
            </a>
          <% } %>

          <% for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) { %>
            <% if (i === currentPage) { %>
              <span class="page-btn active"><%= i %></span>
            <% } else { %>
              <a href="/vehicles?page=<%= i %><%= buildQueryString(filters) %>" class="page-btn"><%= i %></a>
            <% } %>
          <% } %>

          <% if (currentPage < totalPages) { %>
            <a href="/vehicles?page=<%= currentPage + 1 %><%= buildQueryString(filters) %>" class="page-btn">
              <i class="fas fa-chevron-right"></i>
            </a>
          <% } %>
        </div>
      <% } %>
    <% } %>
  </section>

  <!-- QR Scanner Modal -->
  <div class="modal-overlay" id="qrModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">
          <i class="fas fa-qrcode"></i> Scan Vehicle QR Code
        </h3>
        <button class="modal-close" onclick="closeQrModal()">
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class="modal-body">
        <div id="qr-reader"></div>
        <div class="qr-status" id="qrStatus">
          <i class="fas fa-info-circle"></i> Point your camera at the vehicle's QR code
        </div>
      </div>
    </div>
  </div>

  <!-- Toast -->
  <div class="toast" id="toast">
    <i class="fas fa-check-circle"></i>
    <span id="toastMessage">Success!</span>
  </div>

  <!-- Footer -->
  <footer>
    <div class="footer-container">
      <div>
        <div class="footer-brand">
          <img src="/assets/logo-original.png" alt="Before You Sign - Vehicle Verification Platform Logo" height="35">
        </div>
        <p class="footer-desc">
          Empowering car buyers with verified data and holding dealerships accountable through transparent verification.
        </p>
        <div class="footer-social">
          <a href="#" class="social-link"><i class="fab fa-twitter"></i></a>
          <a href="#" class="social-link"><i class="fab fa-linkedin-in"></i></a>
          <a href="#" class="social-link"><i class="fab fa-facebook-f"></i></a>
          <a href="#" class="social-link"><i class="fab fa-instagram"></i></a>
        </div>
      </div>
      <div class="footer-column">
        <h4>Platform</h4>
        <ul class="footer-links">
          <li><a href="/">Home</a></li>
          <li><a href="/vehicles">Browse Vehicles</a></li>
          <li><a href="/#how-it-works">How It Works</a></li>
          <li><a href="/register/dealership">For Dealerships</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>Legal</h4>
        <ul class="footer-links">
          <li><a href="/legal/consumer-protection">Consumer Protection Act</a></li>
          <li><a href="/legal/dispute-resolution">Dispute Resolution</a></li>
          <li><a href="/legal/privacy">Privacy Policy</a></li>
          <li><a href="/legal/terms">Terms of Service</a></li>
        </ul>
      </div>
      <div class="footer-column">
        <h4>Contact</h4>
        <ul class="footer-links">
          <li><a href="mailto:mxolisimkhonza23@gmail.com">mxolisimkhonza23@gmail.com</a></li>
          <li><a href="tel:+27837440206">+27 83 744 0206</a></li>
          <li><a href="#">Johannesburg, South Africa</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <div>&copy; <%= new Date().getFullYear() %> Before You Sign. All rights reserved.</div>
      <div>
        <i class="fas fa-lock"></i> Secure SSL &bull; <i class="fas fa-shield-alt"></i> POPIA Compliant
      </div>
    </div>
  </footer>

  <script>
    // Mobile menu toggle
    function toggleMobileMenu() {
      const menu = document.getElementById('mobileMenu');
      const isActive = menu.classList.toggle('active');
      document.body.style.overflow = isActive ? 'hidden' : '';
    }

    // User menu dropdown toggle
    function toggleUserMenu() {
      const dropdown = document.getElementById('userDropdown');
      dropdown.classList.toggle('show');
    }

    // Close user dropdown when clicking outside
    document.addEventListener('click', (e) => {
      const userMenu = document.getElementById('userMenu');
      const dropdown = document.getElementById('userDropdown');
      
      if (userMenu && !userMenu.contains(e.target)) {
        if (dropdown) dropdown.classList.remove('show');
      }
    });

    // Close mobile menu on resize
    window.addEventListener('resize', () => {
      if (window.innerWidth > 768) {
        const menu = document.getElementById('mobileMenu');
        if (menu) menu.classList.remove('active');
        document.body.style.overflow = '';
      }
    });

    // QR Scanner
    let html5QrcodeScanner;
    const qrModal = document.getElementById('qrModal');
    const qrStatus = document.getElementById('qrStatus');

    function openQrModal() {
      qrModal.classList.add('active');
      document.body.style.overflow = 'hidden';
      
      setTimeout(() => {
        initQrScanner();
      }, 300);
    }

    function closeQrModal() {
      qrModal.classList.remove('active');
      document.body.style.overflow = '';
      
      if (html5QrcodeScanner) {
        html5QrcodeScanner.stop().catch(() => {});
      }
    }

    function initQrScanner() {
      html5QrcodeScanner = new Html5Qrcode('qr-reader');
      
      html5QrcodeScanner.start(
        { facingMode: 'environment' },
        { fps: 10, qrbox: { width: 250, height: 250 } },
        onScanSuccess,
        onScanError
      ).then(() => {
        qrStatus.innerHTML = '<i class="fas fa-camera"></i> Camera ready - Point at QR code';
        qrStatus.className = 'qr-status';
      }).catch(err => {
        qrStatus.innerHTML = '<i class="fas fa-exclamation-triangle"></i> Camera access denied';
        qrStatus.className = 'qr-status error';
      });
    }

    function onScanSuccess(qrCodeMessage) {
      qrStatus.innerHTML = '<i class="fas fa-check-circle"></i> QR code detected!';
      qrStatus.className = 'qr-status success';
      
      let vin;
      try {
        if (qrCodeMessage.startsWith('{')) {
          const parsed = JSON.parse(qrCodeMessage);
          vin = parsed.vin || parsed.VIN || parsed.vehicleId;
        } else {
          vin = qrCodeMessage;
        }
        
        if (vin) {
          setTimeout(() => {
            window.location.href = `/vehicle/vin/${vin.toUpperCase()}`;
          }, 500);
        }
      } catch (e) {
        qrStatus.innerHTML = '<i class="fas fa-exclamation-circle"></i> Invalid QR code';
        qrStatus.className = 'qr-status error';
      }
    }

    function onScanError(errorMessage) {
      // Silent - scanning errors are normal
    }

    // Close modal on overlay click
    qrModal.addEventListener('click', (e) => {
      if (e.target === qrModal) closeQrModal();
    });

    // Close on ESC
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (qrModal.classList.contains('active')) {
          closeQrModal();
        }
        const mobileMenu = document.getElementById('mobileMenu');
        const userDropdown = document.getElementById('userDropdown');
        
        if (mobileMenu && mobileMenu.classList.contains('active')) {
          toggleMobileMenu();
        }
        
        if (userDropdown && userDropdown.classList.contains('show')) {
          userDropdown.classList.remove('show');
        }
      }
    });

    // Filter functionality
    function applyFilter(key, value) {
      const url = new URL(window.location.href);
      if (value) {
        url.searchParams.set(key, value);
      } else {
        url.searchParams.delete(key);
      }
      url.searchParams.delete('page');
      window.location.href = url.toString();
    }

    // Build query string helper
    function buildQueryString(filters) {
      if (!filters) return '';
      const params = new URLSearchParams();
      Object.entries(filters).forEach(([key, value]) => {
        if (value && key !== 'page') params.append(key, value);
      });
      const query = params.toString();
      return query ? '&' + query : '';
    }

    // Toast notification
    function showToast(message, type = 'success') {
      const toast = document.getElementById('toast');
      const toastMessage = document.getElementById('toastMessage');
      toastMessage.textContent = message;
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    }

    // VIN input validation
    const vinInput = document.querySelector('input[name="vin"]');
    if (vinInput) {
      vinInput.addEventListener('input', (e) => {
        e.target.value = e.target.value.toUpperCase().replace(/[^A-HJ-NPR-Z0-9]/g, '');
      });
    }

    // Check for URL parameters (success/error messages)
    const urlParams = new URLSearchParams(window.location.search);
    const successMsg = urlParams.get('success');
    const errorMsg = urlParams.get('error');

    if (successMsg) {
      showToast(decodeURIComponent(successMsg), 'success');
    } else if (errorMsg) {
      showToast(decodeURIComponent(errorMsg), 'error');
    }
  </script>
</body>
</html>