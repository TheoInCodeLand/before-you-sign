                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Tare Weight</span>
                                <span class="spec-value"><%= vehicle.tare_weight ? vehicle.tare_weight + ' kg' : 'N/A' %></span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Liable for Licensing</span>
                                <span class="spec-value"><%= vehicle.date_liability_licensing ? new Date(vehicle.date_liability_licensing).toLocaleDateString() : 'N/A' %></span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Liable for Registration</span>
                                <span class="spec-value"><%= vehicle.date_liable_registration ? new Date(vehicle.date_liable_registration).toLocaleDateString() : 'N/A' %></span>
                            </div>
                        </div>

                        <% if (vehicle.license_numbers) { %>
                            <% try { %>
                                <% const licenses = JSON.parse(vehicle.license_numbers); %>
                                <% if (licenses && licenses.length > 0) { %>
