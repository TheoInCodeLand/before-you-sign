        // ============================================
        // DISPUTE MODAL FUNCTIONS
        // ============================================

        function openDisputeModal() {
            document.getElementById('disputeModal').classList.add('active');
            document.body.style.overflow = 'hidden';
            
            // Reset form
            document.getElementById('disputeForm').reset();
            document.getElementById('disputeForm').style.display = 'block';
            document.getElementById('disputeSuccess').style.display = 'none';
            document.getElementById('submitBtn').disabled = false;
            document.getElementById('submitBtn').classList.remove('loading');
        }

        function closeDisputeModal() {
            document.getElementById('disputeModal').classList.remove('active');
            document.body.style.overflow = '';
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            document.getElementById('toastMessage').textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 5000);
        }

        async function submitDispute(event) {
            event.preventDefault();
            
            const submitBtn = document.getElementById('submitBtn');
            const form = document.getElementById('disputeForm');
            
            // Validate form
            const formData = new FormData(form);
            const category = formData.get('cpa_category');
            const description = formData.get('discrepancy_description');
            const resolution = formData.get('preferred_resolution');
            
            if (!category || !description || !resolution) {
                showToast('Please fill in all required fields');
                return;
            }

            // Show loading state
            submitBtn.disabled = true;
            submitBtn.classList.add('loading');

            try {
                const response = await fetch('/customer/report-dispute', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({
                        vehicle_id: '<%= vehicle.id %>',
                        cpa_category: category,
                        discrepancy_description: description,
                        preferred_resolution: resolution
                    })
                });

                const result = await response.json();

                if (result.success) {
                    // Show success state
                    document.getElementById('disputeForm').style.display = 'none';
                    document.getElementById('disputeSuccess').style.display = 'block';
                    document.getElementById('disputeRef').textContent = 'Reference: ' + result.dispute_id;
                } else {
                    throw new Error(result.error || 'Failed to submit dispute');
                }
            } catch (error) {
                showToast(error.message || 'Failed to submit dispute. Please try again.');
                submitBtn.disabled = false;
                submitBtn.classList.remove('loading');
            }
        }

        // Close modal on overlay click
        document.getElementById('disputeModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeDisputeModal();
            }
        });

        // Close on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') {
                closeDisputeModal();
            }
        });

