                                <span class="verify-status <%= vehicle.registration_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.registration_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-wrench"></i>
