                                    <span class="dealership-badge">Certified</span>
                                <% } %>
                            </div>
                            <div style="font-size: 0.875rem; opacity: 0.8;">Authorized Dealer</div>
                        </div>
                    </div>
                    <div class="dealership-contact">
                        <% if (vehicle.phone) { %>
                            <a href="tel:<%= vehicle.phone %>">
