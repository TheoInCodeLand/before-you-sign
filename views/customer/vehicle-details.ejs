                                    <i class="fas <%= vehicle.vin_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-id-card"></i>
                                    Plate Number
                                </span>
                                <span class="verify-status <%= vehicle.plate_number_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.plate_number_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-cog"></i>
                                    Engine Number
                                </span>
                                <span class="verify-status <%= vehicle.engine_number_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.engine_number_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-tachometer-alt"></i>
                                    Mileage
                                </span>
                                <span class="verify-status <%= vehicle.mileage_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.mileage_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-tools"></i>
                                    Service History
                                </span>
                                <span class="verify-status <%= vehicle.service_history_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.service_history_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
