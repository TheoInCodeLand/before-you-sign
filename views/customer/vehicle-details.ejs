                                        <h4 style="margin-bottom: 1rem; font-size: 0.875rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em;">License Number History</h4>
                                        <div style="display: flex; flex-wrap: wrap; gap: 0.5rem;">
                                            <% licenses.forEach((num, idx) => { %>
                                                <span class="spec-value code">
                                                    <%= idx === 0 ? 'Current: ' : 'Prev: ' %><%= num %>
                                                </span>
                                            <% }) %>
