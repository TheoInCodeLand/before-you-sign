                                    <i class="fas fa-user-check"></i>
                                    Ownership
                                </span>
                                <span class="verify-status <%= vehicle.ownership_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.ownership_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-car-crash"></i>
                                    Accident History
                                </span>
                                <span class="verify-status <%= vehicle.accident_history_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.accident_history_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-exclamation-circle"></i>
                                    Recalls Checked
                                </span>
                                <span class="verify-status <%= vehicle.recall_verified ? 'checked' : 'unchecked' %>">
                                    <i class="fas <%= vehicle.recall_verified ? 'fa-check' : 'fa-minus' %>"></i>
                                </span>
                            </div>
                            <div class="verify-item">
                                <span class="verify-label">
                                    <i class="fas fa-file-alt"></i>
                                    Registration
