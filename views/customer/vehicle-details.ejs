                </div>

                <!-- Registration Info -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <i class="fas fa-file-contract"></i>
                        </div>
                        <h2 class="card-title">Registration & Legal Information</h2>
                    </div>
                    <div class="card-content">
                        <div class="specs-grid">
                            <div class="spec-item">
                                <span class="spec-label">Registration Authority</span>
                                <span class="spec-value"><%= vehicle.registration_authority || 'N/A' %></span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Vehicle Status</span>
