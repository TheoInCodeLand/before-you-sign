                    </div>
                <% } %>

                <!-- System Info -->
                <div class="card">
                    <div class="card-header">
                        <div class="card-icon">
                            <i class="fas fa-info-circle"></i>
                        </div>
                        <h2 class="card-title">Report Information</h2>
                    </div>
                    <div class="card-content">
                        <div class="specs-grid" style="gap: 1rem;">
                            <div class="spec-item">
                                <span class="spec-label">Report Generated</span>
                                <span class="spec-value" style="font-size: 0.875rem;"><%= new Date().toLocaleString() %></span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Last Updated</span>
                                <span class="spec-value" style="font-size: 0.875rem;"><%= new Date(vehicle.updated_at).toLocaleString() %></span>
                            </div>
                            <div class="spec-item">
                                <span class="spec-label">Vehicle ID</span>
