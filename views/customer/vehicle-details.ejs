                            <span class="stat-label">Engine</span>
                            <span class="stat-value"><%= vehicle.engine_capacity || 'N/A' %></span>
                        </div>
                    </div>
                    <div class="stat">
                        <div class="stat-icon">
                            <i class="fas fa-id-card"></i>
                        </div>
                        <div class="stat-content">
                            <span class="stat-label">VIN</span>
                            <span class="stat-value" style="font-family: monospace; font-size: 0.875rem;"><%= vehicle.vin %></span>
                        </div>
                    </div>
                </div>

                <!-- Dealership Info -->
